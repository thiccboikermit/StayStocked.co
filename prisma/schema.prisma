// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HOST
  STOCKER
  ADMIN
}

enum OrderStatus {
  PENDING
  APPROVED
  ASSIGNED
  IN_PROGRESS
  STOCKED
  CANCELLED
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  password          String
  role              UserRole  @default(HOST)
  emailVerified     DateTime?
  image             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Password reset functionality
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  
  // Relations
  properties        Property[]
  orders            Order[]
  stockerProfile    StockerProfile?
  accounts          Account[]
  sessions          Session[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Property {
  id              String         @id @default(cuid())
  name            String
  address         String
  latitude        Float?
  longitude       Float?
  image           String?
  icalUrl         String?        @map("ical_url")
  status          PropertyStatus @default(ACTIVE)
  amenities       Json?          // Store as JSON for flexibility
  hostId          String         @map("host_id")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Relations
  host            User           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  orders          Order[]
  
  @@map("properties")
}

model Order {
  id              String      @id @default(cuid())
  propertyId      String      @map("property_id")
  guestEmail      String      @map("guest_email")
  guestName       String      @map("guest_name")
  checkInDate     DateTime    @map("check_in_date")
  checkOutDate    DateTime    @map("check_out_date")
  numberOfGuests  Int         @map("number_of_guests")
  status          OrderStatus @default(PENDING)
  items           Json        // Store grocery list as JSON
  total           Decimal     @db.Decimal(10, 2)
  stripePaymentId String?     @map("stripe_payment_id")
  stockerId       String?     @map("stocker_id")
  stockedAt       DateTime?   @map("stocked_at")
  stockingPhotos  String[]    @default([]) @map("stocking_photos")
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  property        Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  stocker         User?       @relation(fields: [stockerId], references: [id])
  
  @@map("orders")
}

model StockerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  phone             String?
  vehicleInfo       String?  @map("vehicle_info")
  serviceRadius     Int      @default(25) @map("service_radius") // miles
  isActive          Boolean  @default(true) @map("is_active")
  completedOrders   Int      @default(0) @map("completed_orders")
  rating            Decimal? @db.Decimal(3, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("stocker_profiles")
}
